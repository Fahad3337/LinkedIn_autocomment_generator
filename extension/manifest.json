{
    "manifest_version": 3,
    "name": "CommentFlow",
    "version": "1.0.0",
    "description": "Automate your LinkedIn outreach from post comments.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "alarms"
    ],
    "host_permissions": [
        "*://*.linkedin.com/*",
        "http://localhost:3000/*",
        "https://commentflow.dev/*"
    ],
    "action": {
        "default_popup": "popup/index.html",
        "default_title": "CommentFlow"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "scripts/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "scripts/content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}